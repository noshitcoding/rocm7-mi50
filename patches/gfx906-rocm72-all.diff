diff --git a/ml/backend/ggml/ggml/src/ggml-cuda/solve_tri.cu b/ml/backend/ggml/ggml/src/ggml-cuda/solve_tri.cu
index 177ffc2..440622f 100644
--- a/ml/backend/ggml/ggml/src/ggml-cuda/solve_tri.cu
+++ b/ml/backend/ggml/ggml/src/ggml-cuda/solve_tri.cu
@@ -249,6 +249,37 @@ static void solve_tri_f32_cuda(const float * A,
     }
 }
 
+#ifdef GGML_CUDA_FORCE_MMQ
+// Naive forward-substitution kernel for large n/k that avoids cublas/Tensile.
+// Solves L * X = B where L is lower triangular (row-major), one thread per column.
+// X is modified in-place (caller must copy B->X beforehand).
+static __global__ void solve_tri_f32_naive_kernel(
+        const float * __restrict__ A,
+        float       * __restrict__ X,
+        const int n, const int k,
+        const int64_t ne02,
+        const size_t s02, const size_t s03,
+        const size_t s2,  const size_t s3) {
+    const int col   = blockIdx.y * blockDim.x + threadIdx.x;
+    const int batch = blockIdx.x;
+    if (col >= k) { return; }
+
+    const int64_t i03 = batch / ne02;
+    const int64_t i02 = batch % ne02;
+
+    const float * A_b = A + i03 * s03 + i02 * s02;
+    float       * X_b = X + i03 * s3  + i02 * s2;
+
+    for (int row = 0; row < n; ++row) {
+        float val = X_b[row * k + col];
+        for (int m = 0; m < row; ++m) {
+            val -= A_b[row * n + m] * X_b[m * k + col];
+        }
+        X_b[row * k + col] = val / A_b[row * n + row];
+    }
+}
+#endif // GGML_CUDA_FORCE_MMQ
+
 void ggml_cuda_op_solve_tri(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
     const ggml_tensor * src0 = dst->src[0];  // A (n*n, lower triangular)
     const ggml_tensor * src1 = dst->src[1];  // B (n*k)
@@ -267,9 +298,40 @@ void ggml_cuda_op_solve_tri(ggml_backend_cuda_context & ctx, ggml_tensor * dst)
                            src1->nb[2] / sizeof(float), src1->nb[3] / sizeof(float), dst->nb[2] / sizeof(float),
                            dst->nb[3] / sizeof(float), ctx.stream());
     } else {
+#ifdef GGML_CUDA_FORCE_MMQ
+        // Naive GPU fallback: avoids cublasStrsmBatched which needs Tensile kernels
+        // not available on gfx906. One thread per column, sequential row substitution.
+        const int64_t total_batches = ne02 * ne03;
+        if (total_batches == 0) { return; }
+
+        // Copy B -> X first (same as cublas path)
+        const float * B_d = (const float *) src1->data;
+        float       * X_d = (float *) dst->data;
+        if (X_d != B_d) {
+            CUDA_CHECK(cudaMemcpyAsync(X_d, B_d, n * k * total_batches * sizeof(float),
+                                       cudaMemcpyDeviceToDevice, ctx.stream()));
+        }
+
+        // Launch naive forward-substitution kernel
+        const int threads_x = (k < 256) ? (int)k : 256;
+        dim3 grid_naive(total_batches, (k + threads_x - 1) / threads_x);
+        dim3 block_naive(threads_x);
+
+        solve_tri_f32_naive_kernel<<<grid_naive, block_naive, 0, ctx.stream()>>>(
+            (const float *) src0->data, X_d, n, k, ne02,
+            src0->nb[2] / sizeof(float), src0->nb[3] / sizeof(float),
+            dst->nb[2] / sizeof(float), dst->nb[3] / sizeof(float));
+        CUDA_CHECK(cudaGetLastError());
+#else
         solve_tri_f32_cublas(ctx, (const float *) src0->data, (const float *) src1->data, (float *) dst->data, n, k,
                              ne02, ne03, src0->nb[2] / sizeof(float), src0->nb[3] / sizeof(float),
                              src1->nb[2] / sizeof(float), src1->nb[3] / sizeof(float), dst->nb[2] / sizeof(float),
                              dst->nb[3] / sizeof(float), ctx.stream());
+#endif
     }
 }
